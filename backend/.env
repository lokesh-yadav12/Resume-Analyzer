NODE_ENV=development
PORT=5000
# Use MongoDB Atlas free tier or local MongoDB
# For local: mongodb://localhost:27017/career-boost-ai
# For Atlas: Get connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/career-boost-ai
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173
ML_SERVICE_URL=http://localhost:5001

# Set to true to run without database (demo mode)
DEMO_MODE=true

# OAuth (optional - can be added later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
